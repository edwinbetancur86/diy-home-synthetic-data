# ============================================================
#  .env.example  —  TEMPLATE ONLY (safe to commit)
# ------------------------------------------------------------
#  HOW TO USE:
#   1. Copy this file and rename the copy to ".env"
#   2. Paste your real Anthropic API key after ANTHROPIC_API_KEY=
#   3. Save. The real .env is git-ignored and will NEVER be pushed.
#
#  Never put your real key in THIS file (.env.example) — it is
#  committed to GitHub. Real secrets go in .env only.
# ============================================================

# Your Anthropic API key (starts with "sk-ant-...")
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- Model configuration ---
# Generator: creative work, needs a capable model
GENERATOR_MODEL=claude-sonnet-4-6
# Judge: deterministic scoring, a cheaper/faster model is fine
JUDGE_MODEL=claude-haiku-4-5-20251001

# --- Sampling temperatures ---
# Generator runs warmer (variety); judge runs near-zero (consistency)
GENERATOR_TEMPERATURE=0.8
JUDGE_TEMPERATURE=0.0
